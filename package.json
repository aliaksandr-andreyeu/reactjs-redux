{
    "name": "reactjs-redux",
    "version": "1.0.0",
    "description": "React.js Redux Boilerplate",
    "author": "Aliaksandr Andreyeu",
    "license": "MIT",
    "main": "index.js",
    "scripts": {
        "prebuild": "rimraf build",
        "format": "prettier --write \"src/**/*.{js,scss}\"",
        "start": "webpack-dev-server --mode=development --watch --progress",
        "build:dev": "webpack --mode=development",
        "build:prod": "webpack --mode=production",
        "lint": "eslint --ext .js ./src",
        "lint:fix": "eslint --fix --ext .js ./src",
        "precommit": "lint-staged && npm run lint"
    },
    "browserslist": [
        "last 10 major versions",
        "Chrome >= 4",
        "Explorer >= 8",
        "Firefox >= 3.5",
        "Opera >= 10",
        "Safari >= 4"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/CodeDual/reactjs-redux.git"
    },
    "dependencies": {
        "react": "^16.12.0",
        "react-dom": "^16.12.0",
        "react-redux": "^7.1.3",
        "react-router-dom": "^5.1.2",
        "redux": "^4.0.5",
        "rimraf": "^3.0.1"
    },
    "devDependencies": {
        "@babel/core": "^7.8.4",
        "@babel/plugin-proposal-class-properties": "^7.8.3",
        "@babel/plugin-proposal-decorators": "^7.8.3",
        "@babel/plugin-transform-object-assign": "^7.8.3",
        "@babel/polyfill": "^7.8.3",
        "@babel/preset-env": "^7.8.4",
        "@babel/preset-react": "^7.8.3",
        "autoprefixer": "^9.7.4",
        "babel-eslint": "^10.0.3",
        "babel-loader": "^8.0.6",
        "babel-plugin-import": "^1.13.0",
        "core-js": "^3.6.4",
        "css-loader": "^3.4.2",
        "eslint": "^6.8.0",
        "eslint-loader": "^3.0.3",
        "eslint-plugin-react": "^7.18.3",
        "husky": "^4.2.1",
        "lint-staged": "^8.1.6",
        "mini-css-extract-plugin": "^0.9.0",
        "node-sass": "^4.13.1",
        "optimize-css-assets-webpack-plugin": "^5.0.3",
        "postcss-loader": "^3.0.0",
        "prettier": "^1.19.1",
        "sass-loader": "^8.0.2",
        "source-map-loader": "^0.2.4",
        "terser-webpack-plugin": "^2.3.4",
        "webpack": "^4.41.5",
        "webpack-cli": "^3.3.10",
        "webpack-dev-server": "^3.10.3"
    },
    "lint-staged": {
        "linters": {
            "src/**/*.scss": [
                "npm run format",
                "git add"
            ],
            "src/**/*.js": [
                "npm run format",
                "npm run lint:fix",
                "git add"
            ],
            "./**/*.json": [
                "npm run format",
                "git add"
            ]
        }
    },
    "husky": {
        "hooks": {
            "pre-commit": "npm run precommit"
        }
    }
}
