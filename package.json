{
  "name": "reactjs-redux",
  "version": "0.0.1",
  "description": "React.js Redux Boilerplate",
  "author": "Aliaksandr Andreyeu",
  "license": "MIT",
  "main": "src/index.js",
  "scripts": {
    "format": "prettier --write \"./**/*.{js,json,css,scss}\"",
    "start": "webpack serve --mode development --progress",
    "build:dev": "webpack --mode=development",
    "build:prod": "webpack --mode=production",
    "lint": "npm run lint:style && npm run lint:js",
    "lint:fix": "npm run lint:style:fix && npm run lint:js:fix",
    "lint:style": "stylelint \"./**/*.{css,scss}\"",
    "lint:style:fix": "stylelint \"./**/*.{css,scss}\" --fix",
    "lint:js": "eslint --ext .js,.json ./src",
    "lint:js:fix": "eslint --fix --ext .js,.json ./src",
    "precommit": "lint-staged"
  },
  "browserslist": [
    "last 10 major versions",
    "Chrome >= 4",
    "Explorer >= 8",
    "Firefox >= 3.5",
    "Opera >= 10",
    "Safari >= 4"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/CodeDual/reactjs-redux.git"
  },
  "dependencies": {
    "axios": "^0.21.1",
    "prop-types": "^15.7.2",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-redux": "^7.2.3",
    "react-router-dom": "^5.2.0",
    "redux": "^4.0.5",
    "redux-thunk": "^2.3.0"
  },
  "devDependencies": {
    "@babel/core": "^7.13.14",
    "@babel/plugin-proposal-class-properties": "^7.13.0",
    "@babel/plugin-proposal-decorators": "^7.13.5",
    "@babel/plugin-transform-object-assign": "^7.12.13",
    "@babel/polyfill": "^7.12.1",
    "@babel/preset-env": "^7.13.12",
    "@babel/preset-react": "^7.13.13",
    "autoprefixer": "^10.2.5",
    "babel-eslint": "^10.1.0",
    "babel-loader": "^8.2.2",
    "babel-plugin-import": "^1.13.3",
    "core-js": "^3.10.0",
    "css-loader": "^5.2.0",
    "eslint": "^7.23.0",
    "eslint-config-prettier": "^8.1.0",
    "eslint-loader": "^4.0.2",
    "eslint-plugin-prettier": "^3.3.1",
    "eslint-plugin-react": "^7.23.1",
    "husky": "^4.2.5",
    "lint-staged": "^10.2.13",
    "mini-css-extract-plugin": "^1.4.0",
    "node-sass": "^5.0.0",
    "optimize-css-assets-webpack-plugin": "^5.0.4",
    "postcss-loader": "^5.2.0",
    "prettier": "^2.2.1",
    "sass-loader": "^11.0.1",
    "source-map-loader": "^2.0.1",
    "stylelint": "^13.12.0",
    "stylelint-config-prettier": "^8.0.2",
    "stylelint-config-standard": "^21.0.0",
    "terser-webpack-plugin": "^5.1.1",
    "webpack": "^5.30.0",
    "webpack-cli": "^4.6.0"
  },
  "lint-staged": {
    "./**/*.{css,scss,js}": [
      "npm run format",
      "npm run lint:fix"
    ],
    "./**/*.json": [
      "npm run format"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run precommit"
    }
  }
}
